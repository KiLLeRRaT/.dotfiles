{
  "layer": "top",
  "position": "bottom",
  "height": 34,
  "spacing": 8,
  "modules-left": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-center": [],
  "modules-right": [
    "pulseaudio",
    "network",
    "disk",
    "battery",
    "memory",
    "cpu",
    "clock",
    "tray"
  ],
  "sway/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{name}"
  },
  "sway/mode": {
    "format": "ΎΔπ {}"
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "ΎΛΦ  {volume}%",
    "format-muted": "Ό╗ρ  mute",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "network": {
    "format-wifi": "≤░Ψσ {ipaddr}",
    "format-ethernet": "≤░ΙΑ {ipaddr}",
    "format-disconnected": "≤░Ψς",
    "tooltip-format": "{ifname} via {gwaddr}"
  },
  "disk": {
    "path": "/",
    "format": "έδΒ {free}",
    "states": {
      "warning": 90,
      "critical": 95
    },
    "tooltip-format": "{used} used / {total} total ({percentage_used}%)"
  },
  "battery": {
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{icon} {capacity}% {time}",
    "format-charging": "ΎΘο {capacity}% {time}",
    "format-plugged": "ΎΘο {capacity}% {time}",
    "format-time": "{H}:{m}",
    "format-icons": [
      "≤░Β║",
      "≤░Β╗",
      "≤░Β╝",
      "≤░Β╜",
      "≤░Β╛",
      "≤░Β┐",
      "≤░ΓΑ",
      "≤░ΓΒ",
      "≤░ΓΓ",
      "≤░Β╣"
    ]
  },
  "memory": {
    "format": "≤░Ξδ {used:0.1f}G/{avail:0.1f}G"
  },
  "cpu": {
    "format": "ΎΜδ {usage}%"
  },
  "clock": {
    "interval": 1,
    "format": "{:%a %d %b %H:%M:%S}"
  },
  "tray": {
    "spacing": 10
  }
}
